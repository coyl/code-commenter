# Backend (api)
GEMINI_API_KEY=your-gemini-api-key
PORT=8080
ALLOWED_ORIGINS=http://localhost:3010

# Frontend: API URL used by the browser (baked in at web build time)
# Must match the host:port where the api service is exposed (see compose ports).
NEXT_PUBLIC_API_URL=http://localhost:8090

# Optional: override model IDs
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# GEMINI_TTS_MODEL=gemini-2.5-pro-preview-tts  (fallback when Live API model unavailable)
#S3_REGION=
#S3_ENDPOINT=
#S3_ACCESS_KEY=
#S3_SECRET_KEY=

#S3_BUCKET=code-commenter