# Backend (api)
GEMINI_API_KEY=your-gemini-api-key
PORT=8080
ALLOWED_ORIGINS=http://localhost:3010

# Optional: Google OAuth + session (when set, generation requires sign-in)
# GOOGLE_CLIENT_ID=your-oauth-client-id
# GOOGLE_CLIENT_SECRET=your-oauth-client-secret
# AUTH_CALLBACK_URL=http://localhost:8080/auth/callback
# SESSION_SECRET=at-least-32-byte-random-string

# Optional: Firestore for job index (enables "My jobs" list when auth is enabled)
# FIRESTORE_PROJECT_ID=your-gcp-project-id

# Frontend: API URL used by the browser (baked in at web build time)
# Must match the host:port where the api service is exposed (see compose ports).
NEXT_PUBLIC_API_URL=http://localhost:8090

# Optional: override model IDs
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# GEMINI_TTS_MODEL=gemini-2.5-pro-preview-tts  (fallback when Live API model unavailable)
#S3_REGION=
#S3_ENDPOINT=
#S3_ACCESS_KEY=
#S3_SECRET_KEY=

#S3_BUCKET=code-commenter